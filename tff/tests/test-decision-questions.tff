%
%

tff(axiom_fast_active, axiom,
  is_active(fast)
).

tff(axion_no_engine_disabled, axiom,
  ![E: engine]:
  (
    ~engine_disabled(E)
  )
).


tff(question_decl, question,
  ?[M : modelet]:
  (
    modelet_models_concept(M, decision)
    &
    modelet_has_property(M, absolute_size_prop)
  )
).
