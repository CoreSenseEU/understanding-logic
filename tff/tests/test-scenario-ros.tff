tff(all_phenomena, axiom,
  ![P : phenomenon]:
  (
    P = phenomenon_1
    |
    P = phenomenon_2
    |
    P = phenomenon_3
    |
    P = phenomenon_4
    |
    P = phenomenon_5
    |
