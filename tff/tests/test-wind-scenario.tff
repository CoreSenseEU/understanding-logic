% Wind Estimation Scenario

%include('understanding-logic/tff/model/properties.tff').
include('understanding-logic/tff/model/top.tff').

%%%%%% Phenomena
%---------------------------------------------------------------------------
% Inertia
tff(inertia_decl, type,
  inertia : concept
).

% Geolocation
tff(geolocation_decl, type,
  geolocation : concept
).

% Force
tff(force_decl, type,
  force : concept
).

% Drone State
tff(drone_state_decl, type,
  drone_state : concept
).

% Drone State Evolution
tff(drone_state_evolution_decl, type,
  drone_state_evolution : concept
).

% Wind
tff(wind, type,
  wind : concept
).

% Trajectory
tff(trajectory, type,
  trajectory : concept
).

tff(concept_distinctness, axiom,
  $distinct(inertia, geolocation, force, drone_state, drone_state_evolution, wind, trajectory)
).


%%%%%% Formalisms
%---------------------------------------------------------------------------

tff(navSatFix_msg_decl, type,
  navSatFix_msg : formalism
).

tff(imu_msg_decl, type,
  imu_msg : formalism
).

tff(vector3_msg_decl, type,
  vector3_msg : formalism
).

tff(drone_state_msg_decl, type,
  drone_state_msg : formalism
).

tff(drone_state_evolution_msg_decl, type,
  drone_state_evolution_msg : formalism
).


tff(formalisms_are_distinct, axiom,
  $distinct(navSatFix_msg, imu_msg, vector3_msg, drone_state_msg, drone_state_evolution_msg)
).


%%%%%% Templates
%---------------------------------------------------------------------------

% GNSS template
tff(gnss_template_decl, type,
  gnss_template : template
).

tff(gnss_template_no_requirements, axiom,
  ~?[R : requirement]:
    is_part_of(R, gnss_template)
).

tff(gnss_template_no_creator_requirements, axiom,
  ~?[E: engine]:
    template_has_creator_requirement(gnss_template, E)
).

tff(gnss_template_topic, axiom,
  ![C : concept]:
  (
    template_has_concept_requirement(gnss_template, C) <=> C = geolocation
  )
).

tff(gnss_template_formalism, axiom,
  template_formalism_requirement(gnss_template) = navSatFix_msg
).

tff(gnss_template_representation_class, axiom,
  ~?[R : representation_class]:
    template_has_representation_class_requirement(gnss_template, R)
).

tff(gnss_template_no_location_requirements, axiom,
  ~?[SPT: spacetime_point]:
    template_has_location_requirement(gnss_template, SPT)
).

tff(gnss_template_no_extent_requirements, axiom,
  ~?[E: extent]:
    template_has_extent_requirement(gnss_template, E)
).

