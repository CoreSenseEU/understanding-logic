% Modelets and engines
include('understanding-logic/tff/model/fundamental-concepts.tff').
include('understanding-logic/tff/model/engines.tff').



tff(decl_exert1, type,
  exert1: (engine * modelet) > modelet
).



tff(decl_defines_input1, type,
  defines_input1 : (template * engine) > $o
).



tff(decl_exertable1, type,
  exertable1: (engine * modelet) > $o
).
% Modelets are exertable by Engines (no sets) 1
tff(axiom_modelet_is_exertable1, axiom,
  ![M1: modelet,  T1: template, E: engine, R: engine_requirement]:
  (
    (
      inputs_match(M1, T1)
      &
      defines_input1(T1, E)
      &
      (is_active(R) => engine_meets_requirement(E, R))
    )
    =>
    exertable1(E, M1)
  )
).



tff(axiom_engines_impart_formalism1, axiom,
  ![E: engine, IM1: modelet, OM: modelet]:
  (
    (
      exertable1(E, IM1)
      &
      exert1(E, IM1) = OM
    )
    =>
    formalism_of_modelet(OM) = output_modelet_formalism(E)
  )
).



% Engines are creators of Modelets
tff(axiom_engines_are_creators_of_modelets1, axiom,
  ![E: engine, IM1: modelet, OM: modelet]:
  (
    (
      exertable1(E, IM1)
      &
      exert1(E, IM1) = OM
    )
    =>
    modelet_has_creator(OM, E)
  )
).



