%%% Input Modelets
%---------------------------------------------------------------------------

% IMU measurement
tff(imu0_modelet_decl, type,
  imu0_modelet : modelet
).

tff(imu0_modelet_creator, axiom,
  ~?[E : engine]:
    modelet_has_creator(imu0_modelet, E)
).

%tff(imu0_modelet_parents, axiom,
%  parents_of_modelet(imu0_modelet) = empty_ms
%).

tff(imu0_modelet_models_inertia, axiom,
  ![C : concept]:
  (
    modelet_models_concept(imu0_modelet, C) <=> C = inertia
  )
).

tff(imu0_modelet_formalism, axiom,
  formalism_of_modelet(imu0_modelet) = imu_msg
).

% GNSS data
tff(gnss0_modelet_decl, type,
  gnss0_modelet : modelet
).

tff(gnss0_modelet_creator, axiom,
  ~?[E : engine]:
    modelet_has_creator(gnss0_modelet, E)
).

%tff(gnss0_modelet_parents, axiom,
%  parents_of_modelet(gnss0_modelet) = empty_ms
%).

tff(gnss0_modelet_models_geolocation, axiom,
  ![C : concept]:
  (
    modelet_models_concept(gnss0_modelet, C) <=> C = geolocation
  )
).

tff(gnss0_modelet_formalism, axiom,
  formalism_of_modelet(gnss0_modelet) = navSatFix_msg
).

% Rotor force data
tff(rotor_force0_modelet_decl, type,
  rotor_force0_modelet : modelet
).

tff(rotor_force0_modelet_creator, axiom,
  ~?[E : engine]:
    modelet_has_creator(rotor_force0_modelet, E)
).

%tff(rotor_force0_modelet_parents, axiom,
%  parents_of_modelet(rotor_force0_modelet) = empty_ms
%).

tff(rotor_force0_modelet_models_force, axiom,
  ![C : concept]:
  (
    modelet_models_concept(rotor_force0_modelet, C) <=> C = force
  )
).

tff(rotor_force0_modelet_formalism, axiom,
  formalism_of_modelet(rotor_force0_modelet) = vector3_msg
).

tff(trajectory0_modelet_decl, type,
  trajectory0_modelet : modelet
).

tff(trajectory0_modelet_creator, axiom,
  ~?[E : engine]:
    modelet_has_creator(trajectory0_modelet, E)
).

%tff(trajectory0_modelet_parents, axiom,
%  parents_of_modelet(trajectory0_modelet) = empty_ms
%).

tff(trajectory0_has_vector3_msg_formalims, axiom,
  formalism_of_modelet(trajectory0_modelet) = vector3_msg
).

tff(trajectory0_modelet_models_trajectory, axiom,
  ![C : concept]:
  (
    modelet_models_concept(trajectory0_modelet, C) <=> C = trajectory
  )
).


tff(wind0_modelet_decl, type,
  wind0_modelet : modelet
).

tff(wind0_modelet_creator, axiom,
  ~?[E : engine]:
    modelet_has_creator(wind0_modelet, E)
).

%tff(wind0_modelet_parents, axiom,
%  parents_of_modelet(wind0_modelet) = empty_ms
%).

tff(wind0_has_vector3_msg_formalims, axiom,
  formalism_of_modelet(wind0_modelet) = vector3_msg
).

tff(wind0_modelet_models_wind, axiom,
  ![C : concept]:
  (
    modelet_models_concept(wind0_modelet, C) <=> C = wind
  )
).


tff(input_modelets_are_distinct, axiom,
  $distinct(wind0_modelet, trajectory0_modelet, imu0_modelet, gnss0_modelet)
).

%%%%%% Engines
%---------------------------------------------------------------------------
%%% Drone State Estimator
%-----------------------------------
tff(drone_state_estimation_engine_decl, type,
  dse_engine : engine
).

tff(dse_engine_output_formalism, axiom,
  output_modelet_formalism(dse_engine) = drone_state_msg
).

tff(dse_engine_output_topic, axiom,
  ![C : concept]:
  (
    is_output_modelet_concept(dse_engine, C)
    <=>
    C = drone_state
  )
).

tff(dse_engine_output_representation_class, axiom,
  ~?[R : representation_class]:
    is_output_modelet_representation_class(dse_engine, R)
).

tff(dse_engine_defined_input, axiom,
  defines_input2(gnss_template, imu_template, dse_engine)
).



%%% Drone Evolution Estimator
%-----------------------------------
tff(drone_state_evolution_estimation_engine_decl, type,
  dsee_engine : engine
).

tff(drone_state_evolution_engine_output_formalism, axiom,
  output_modelet_formalism(dsee_engine) = drone_state_evolution_msg
).

tff(dsee_engine_output_representation_class, axiom,
  ~?[R : representation_class]:
    is_output_modelet_representation_class(dsee_engine, R)
).

tff(drone_state_evolution_engine_output_topic, axiom,
  ![C : concept]:
  (
    is_output_modelet_concept(dsee_engine, C)
    <=>
    C = drone_state_evolution
  )
).

tff(dsee_engine_input_define, axiom,
  defines_input3(ds_template, wind_template, trajectory_template, dsee_engine)
).


%%% Wind Estimator
%-----------------------------------
tff(wind_estimation_engine_decl, type,
  we_engine : engine
).

tff(wind_estimation_engine_output_formalism, axiom,
  output_modelet_formalism(we_engine) = vector3_msg
).

tff(we_engine_output_representation_class, axiom,
  ~?[R : representation_class]:
    is_output_modelet_representation_class(we_engine, R)
).

tff(wind_estimation_engine_output_topic, axiom,
  ![C : concept]:
  (
    is_output_modelet_concept(we_engine, C)
    <=>
    C = wind
  )
).


tff(wee_engine_defined_input, axiom,
  defines_input2(ds_template, dse_template, we_engine)
).


tff(no_engine_requirements, axiom,
  ![R: requirement]:
    ~is_active(R)
).


tff(question_decl, question,
  ?[M : modelet]:
  (
    ~(M = wind0_modelet)
    &
    modelet_models_concept(M, wind) 
  )
).



