include('tff/model/properties.tff').

tff(zero_decl, type, zero : $real).
%%%  phenomena  %%% 
tff(phenomenon_1_decl, type, phenomenon_1 : phenomenon).
tff(phenomenon_2_decl, type, phenomenon_2 : phenomenon).
tff(all_phenomena, axiom,
  ![P : phenomenon]:
  (
    P = phenomenon_1
    |
    P = phenomenon_2
  )
).

%%%  formalisms  %%%
tff(formalism_1_decl, type, formalism_1 : formalism).
tff(formalism_2_decl, type, formalism_2 : formalism).
tff(all_formalisms, axiom,
  ![F : formalism]:
  (
    F = formalism_1
    |
    F = formalism_2
  )
).

%%%  properties and requirements  %%%
tff(property_1_decl, type, prop_1 : property).
tff(property_1_uses_formalism_decl, axiom,
  type_of_p(prop_1) = formalism_1
).
tff(property_1_has_value_0, axiom,
  has_value(prop_1) = zero
).

tff(requirement_1_decl, type, req_1 : requirement).
tff(requirement_1_uses_formalism_decl, axiom,
  type_of_r(req_1) = formalism_1
).
tff(requirement_1_has_permissible_value_0, axiom,
  is_permissible(req_1, zero)
).

tff(property_2_decl, type, prop_2 : property).
tff(property_2_uses_formalism_decl, axiom,
  type_of_p(prop_2) = formalism_1
).
tff(property_2_has_value_0, axiom,
  has_value(prop_2) = zero
).

tff(requirement_2_decl, type, req_2 : requirement).
tff(requirement_2_uses_formalism_decl, axiom,
  type_of_r(req_2) = formalism_1
).
tff(requirement_2_has_permissible_value_0, axiom,
  is_permissible(req_2, zero)
).

tff(all_props, axiom,
  ![P : property]:
  (
    P = prop_1
    |
    P = prop_2
  )
).

tff(all_reqs, axiom,
  ![R : requirement]:
  (
    R = req_1
    |
    R = req_2
  )
).

%%%  templates and modelets  %%%
tff(modelet_1_decl, type, modelet_1 : modelet).
tff(modelet_1_has_property_2, axiom,
  is_property_of_m(prop_2, modelet_1)
).
tff(modelet_1_has_property_1, axiom,
  is_property_of_m(prop_1, modelet_1)
).
tff(modelet_1_of_phenomenon_1, axiom,
  referent_of_m(modelet_1) = phenomenon_1
).
tff(modelet_1_has_formalism_1, axiom,
  formalism_of_m(modelet_1) = formalism_1
).

tff(template_1_decl, type, template_1 : template).
tff(template_1_has_requirement_2, axiom,
  is_part_of(req_2, template_1)
).
tff(template_1_has_requirement_1, axiom,
  is_part_of(req_1, template_1)
).
tff(template_1_of_phenomenon_1, axiom,
  referent_of_t(template_1) = phenomenon_1
).
tff(template_1_has_formalism_1, axiom,
  formalism_of_t(template_1) = formalism_1
).
tff(template_1_requirements, axiom,
  ![R : requirement]:
  (
    is_part_of(R, template_1)
    =>
    (
      R = req_2
      |
      R = req_1
    )
  )
).

tff(modelet_2_decl, type, modelet_2 : modelet).
tff(modelet_2_has_property_1, axiom,
  is_property_of_m(prop_1, modelet_2)
).
tff(modelet_2_has_property_2, axiom,
  is_property_of_m(prop_2, modelet_2)
).
tff(modelet_2_of_phenomenon_1, axiom,
  referent_of_m(modelet_2) = phenomenon_1
).
tff(modelet_2_has_formalism_2, axiom,
  formalism_of_m(modelet_2) = formalism_2
).

tff(template_2_decl, type, template_2 : template).
tff(template_2_has_requirement_1, axiom,
  is_part_of(req_1, template_2)
).
tff(template_2_has_requirement_2, axiom,
  is_part_of(req_2, template_2)
).
tff(template_2_of_phenomenon_1, axiom,
  referent_of_t(template_2) = phenomenon_1
).
tff(template_2_has_formalism_2, axiom,
  formalism_of_t(template_2) = formalism_2
).
tff(template_2_requirements, axiom,
  ![R : requirement]:
  (
    is_part_of(R, template_2)
    =>
    (
      R = req_1
      |
      R = req_2
    )
  )
).

tff(modelet_3_decl, type, modelet_3 : modelet).
tff(modelet_3_has_property_1, axiom,
  is_property_of_m(prop_1, modelet_3)
).
tff(modelet_3_has_phenomenon_2, axiom,
  referent_of_m(modelet_3) = phenomenon_2
).
tff(modelet_3_has_formalism_2, axiom,
  formalism_of_m(modelet_3) = formalism_2
).

tff(all_modelets, axiom,
  ![M : modelet]:
  (
    M = modelet_1
    |
    M = modelet_2
    |
    M = modelet_3
  )
).
tff(all_templates, axiom,
  ![T : template]:
  (
    T = template_1
    |
    T = template_2
  )
).

%%%  template sets  %%%
tff(template_set_1_decl, type, template_set_1 : template_set).
tff(template_2_in_template_set_1, axiom,
  in_set_t(template_2, template_set_1)
).

tff(template_1_in_template_set_1, axiom,
  in_set_t(template_1, template_set_1)
).

tff(template_set_1_templates, axiom,
  ![T : template]:
  (
    in_set_t(T, template_set_1)
    =>
    (
      T = template_2
      |
      T = template_1
    )
  )
).

tff(template_set_2_decl, type, template_set_2 : template_set).
tff(template_2_in_template_set_2, axiom,
  in_set_t(template_2, template_set_2)
).

tff(template_set_2_templates, axiom,
  ![T : template]:
  (
    in_set_t(T, template_set_2)
    =>
    (
      T = template_2
    )
  )
).

tff(all_template_sets, axiom,
  ![TS : template_set]:
  (
    TS = template_set_1
    |
    TS = template_set_2
  )
).

%%%  engines  %%%
tff(engine_1_decl, type, engine_1 : engine).
tff(engine_1_has_property_1_decl, axiom,
  is_property_of_e(prop_1, engine_1)
).
tff(engine_1_uses_template_set_1_decl, axiom,
  is_interface_of(template_set_1, engine_1)
).

tff(engine_2_decl, type, engine_2 : engine).
tff(engine_2_has_property_2_decl, axiom,
  is_property_of_e(prop_2, engine_2)
).
tff(engine_2_has_property_1_decl, axiom,
  is_property_of_e(prop_1, engine_2)
).
tff(engine_2_uses_template_set_1_decl, axiom,
  is_interface_of(template_set_1, engine_2)
).

tff(all_engines, axiom,
  ![E : engine]:
  (
    E = engine_1
    |
    E = engine_2
  )
).

%%%  modelet sets  %%%
tff(modelet_sets_of_size_1_exist, axiom,
  ![M1: modelet]:
    ?[MS: modelet_set]:
    (
      in_set_m(M1, MS)
    )  
).

tff(modelet_sets_of_size_2_exist, axiom,
  ![M1: modelet, M2: modelet]:
    ?[MS: modelet_set]:
    (
      in_set_m(M1, MS)
      &
      in_set_m(M2, MS)
    )  
).


%%%  why is this required????   %%%
tff(ms_1_decl, type, ms_1 : modelet_set).
tff(hardcode_hack, axiom, 
  (
    in_set_m(modelet_1, ms_1)
    &
    in_set_m(modelet_2, ms_1)
  )
).
