% Set of Templates
tff(decl_template_set, type,
  template_set : $tType
).



% Set Membership of Templates
tff(decl_set_template_membership, type,
  is_in_template_set : (template * template_set) > $o
).



% Engines have template sets as interface definition
tff(decl_engine_input, type,
  interface_of: (engine) > template_set
).



% Sets of Modelets can match Sets of Modelet Templates
tff(decl_interfaces_match, type,
  interfaces_match : (modelet_set * template_set) > $o
).
tff(axiom_modelet_sets_matches_template_sets, axiom,
  ! [MS: modelet_set, TS: template_set]:
  (
    ! [T : template]:
    (
      is_in_template_set(T, TS)
      =>
      ? [M : modelet]:
      (
        inputs_match(M, T)
        &
        is_in_modelet_set(M, MS)
      )
    )
    =>
    interfaces_match(MS, TS)
  )
).



% Modelet Sets are exertable by Engines
tff(axiom_modelet_set_is_exertable, axiom,
  ! [MS: modelet_set, E : engine]:
  (
   interfaces_match(MS, interface_of(E))
   =>
   exertable(E, MS)
  )
).
