tff(axiom_engine_may_impart_representation_class3, axiom,
  ![E: engine, IM1: modelet, IM2: modelet, IM3: modelet, OM: modelet, R: representation_class]:
  (
    (
      exertable3(E, IM1, IM2, IM3)
      &
      exert3(E, IM1, IM2, IM3) = OM
      &
      is_output_modelet_representation_class(E, R)
    )
    =>
    modelet_has_representation_class(OM, R)
  )
).



tff(axiom_engine_may_impart_topic3, axiom,
  ![E: engine, IM1: modelet, IM2: modelet, IM3: modelet, OM: modelet, C: concept]:
  (
    (
      exertable3(E, IM1, IM2, IM3)
      &
      exert3(E, IM1, IM2, IM3) = OM
      &
      is_output_modelet_concept(E, C)
    )
    =>
    modelet_models_concept(OM, C) 
  )
).



% Engine outputs have properties
tff(axiom_engine_may_impart_property3, axiom,
  ! [E: engine, IM1: modelet, IM2: modelet, IM3: modelet, OM: modelet, P: property]:
  (
    (
      exertable3(E, IM1, IM2, IM3)
      &
      exert3(E, IM1, IM2, IM3) = OM
      &
      engine_imparts_output_property(E, P)
    )
    =>
    modelet_has_property(OM, P)
  )
).



tff(axiom_engine_may_transit_property3, axiom,
  ! [E: engine, IM1: modelet, IM2: modelet, IM3: modelet, OM: modelet, P: property]:
  (
    (
      exertable3(E, IM1, IM2, IM3)
      &
      exert3(E, IM1, IM2, IM3) = OM
      &
      engine_transits_property(E, P)
      &
      (
        modelet_has_property(IM1, P)
        |
        modelet_has_property(IM2, P)
        |
        modelet_has_property(IM3, P)
      )
    )
    =>
    modelet_has_property(OM, P)
  )
).
