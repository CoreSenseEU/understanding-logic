tff(axiom_engine_may_impart_representation_class2, axiom,
  ![E: engine, IM1: modelet, IM2: modelet, OM: modelet, R: representation_class]:
  (
    (
      exertable2(E, IM1, IM2)
      &
      exert2(E, IM1, IM2) = OM
      &
      is_output_modelet_representation_class(E, R)
    )
    =>
    modelet_has_representation_class(OM, R)
  )
).



tff(axiom_engine_may_impart_topic2, axiom,
  ![E: engine, IM1: modelet, IM2: modelet, OM: modelet, C: concept]:
  (
    (
      exertable2(E, IM1, IM2)
      &
      exert2(E, IM1, IM2) = OM
      &
      is_output_modelet_concept(E, C)
    )
    =>
    modelet_models_concept(OM, C) 
  )
).


% Engine outputs have properties
tff(axiom_engine_may_impart_property2, axiom,
  ! [E: engine, IM1: modelet, IM2: modelet, OM: modelet, P: property]:
  (
    (
      exertable2(E, IM1, IM2)
      &
      exert2(E, IM1, IM2) = OM
      &
      engine_imparts_output_property(E, P)
    )
    =>
    modelet_has_property(OM, P)
  )
).

tff(axiom_engine_may_transit_property2, axiom,
  ! [E: engine, IM1: modelet, IM2: modelet, OM: modelet, P: property]:
  (
    (
      exertable2(E, IM1, IM2)
      &
      exert2(E, IM1, IM2) = OM
      &
      engine_transits_property(E, P)
      &
      (
        modelet_has_property(IM1, P)
        |
        modelet_has_property(IM2, P)
      )
    )
    =>
    modelet_has_property(OM, P)
  )
).
