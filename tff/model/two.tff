% Modelets and engines
include('understanding-logic/tff/model/engines.tff').



tff(decl_exert2, type,
  exert2: (engine * modelet * modelet) > modelet
).



tff(decl_defines_input2, type,
  defines_input2 : (template * template * engine) > $o
).



tff(decl_exertable2, type,
  exertable2: (engine * modelet * modelet) > $o
).
% Modelets are exertable by Engines (no sets) 2
tff(axiom_modelet_is_exertable2, axiom,
  ![M1: modelet, M2: modelet, T1: template, T2: template, E: engine, R: requirement]:
  (
    (
      inputs_match(M1, T1)
      &
      inputs_match(M2, T2)
      &
      defines_input2(T1, T2, E)
      &
      (is_active(R) => engine_meets_requirement(E, R))
    )
    =>
    exertable2(E, M1, M2)
  )
).



tff(axiom_engines_impart_formalism2, axiom,
  ![E: engine, IM1: modelet, IM2: modelet, OM: modelet]:
  (
    (
      exertable2(E, IM1, IM2)
      &
      exert2(E, IM1, IM2) = OM
    )
    =>
    formalism_of_modelet(OM) = output_modelet_formalism(E)
  )
).



% Engines are creators of Modelets
tff(axiom_engines_are_creators_of_modelets2, axiom,
  ![E: engine, IM1: modelet, IM2: modelet, OM: modelet]:
  (
    (
      exertable2(E, IM1, IM2)
      &
      exert2(E, IM1, IM2) = OM
    )
    =>
    modelet_has_creator(OM, E)
  )
).



