tff(conjecture7, conjecture,
  ?[E1: engine, E2: engine, US1 : modelet_set, US2 : modelet_set, US3: modelet_set, MS1: modelet_set, MS2: modelet_set, M1 : modelet, M2: modelet]:
  (
    exertion(E1, MS1, M1, US1) = US2
    &
    exertion(E2, MS2, M2, US2) = US3
  )
).
