%    (is_in_modelet_set(M1, MS) | M1 = M2 | M1 = M3)
%  )
%).



% Exertion of a Modelet Set results in a Modelet
tff(decl_exert, type,
  exert: (engine * modelet_set) > modelet
).



%% Engines impart formalisms unto Modelets
tff(axiom_engines_impart_formalism, axiom,
  ![E: engine, MS: modelet_set, M: modelet]:
  (
    (
      exertable(E, MS)
      &
      exert(E, MS) = M
    )
    =>
    (
      formalism_of_modelet(M) = output_modelet_formalism(E)
      &
      modelet_has_creator(M, E)
%      &
%      parents_of_modelet(M) = MS
    )
  )
).



% Engines are creators of Modelets
tff(axiom_engines_are_creators_of_modelets, axiom,
  ![E: engine, MS: modelet_set, M: modelet]:
  (
    (
      exertable(E, MS)
      &
      exert(E, MS) = M
    )
    =>
    modelet_has_creator(M, E)
  )
).



% ModeletSets are parents of Modelets
tff(axiom_modelet_sets_are_parents_to_modelets, axiom,
  ![E: engine, MS: modelet_set, M: modelet]:
  (
    (
      exertable(E, MS)
      &
      exert(E, MS) = M
    )
    =>
    parents_of_modelet(M) = MS
  )
).



%% Engines may impart representation_classs unto Modelets
tff(axiom_engine_may_impart_representation_class, axiom,
  ![E: engine, MS: modelet_set, M: modelet, R: representation_class]:
  (
    (
      exertable(E, MS)
      &
      exert(E, MS) = M
      &
      is_output_modelet_representation_class(E, R)
    )
    =>
    modelet_has_representation_class(M, R)
  )
).



%% Engines may impart topic unto Modelets
tff(axiom_engine_may_impart_topic, axiom,
  ![E: engine, MS: modelet_set, M: modelet, C: concept]:
  (
    (
      exertable(E, MS)
      &
      exert(E, MS) = M
      &
      is_output_modelet_concept(E, C)
    )
    =>
    modelet_models_concept(M, C) 
  )
).



% Engine outputs have properties
tff(axiom_engine_may_impart_property, axiom,
  ! [E: engine, MS: modelet_set, M: modelet, P: property]:
  (
    (
      exertable(E, MS)
      &
      exert(E, MS) = M
      &
      engine_imparts_output_property(E, P)
    )
    =>
    modelet_has_property(M, P)
  )
).


