% Modelets and engines
include('understanding-logic/tff/model/fundamental-concepts.tff').

% Engines
tff(decl_engine, type,
  engine : $tType
).

tff(decl_engine_output_formalism, type,
  output_modelet_formalism : engine > formalism
).
tff(decl_engine_output_topic, type,
  is_output_modelet_topic : (engine * phenomenon_class) > $o
).
% Engines can have processing characteristics, such as delay or resource blockage/consumption
% TBD later

% Engines can impart processing semantics unto their output modelets
tff(decl_engine_imparts_role, type,
  is_output_modelet_role : (engine * role) > $o
).


% Modelets
tff(decl_modelet, type,
  modelet : $tType
).

% Each Modelet has exactly one formalism. A language in which it is encoded. A class in the modelling model. A ROSMessage. e.g. 'sensor_msgs/Image'
tff(decl_formalism_of_modelet, type,
  formalism_of_modelet : modelet > formalism
).

% Modelets have a date of creation. They were created at that date.
tff(decl_creation_date, type,
  modelet_creation_date : modelet > $real
).

% Modelets may have a time-interval/date of reference. They refer to an observation made at that date. Temporal scope.
tff(decl_modelet_location, type,
  modelet_location : modelet > spacetime_point
).

% Modelets may have an area/volume/location of reference. They refer to an observation made at some point. Spatial scope.
tff(decl_modelet_extent, type,
  modelet_extent : modelet > extent
).

% Modelets may be associated with a concept/have a topic. A class in the world model. e.g. 'ice cream'
tff(decl_topic_of_modelet, type,
  is_topic_of_modelet : (modelet * phenomenon_class) > $o
).

% Modelets have model properties/characteristics. e.g. 'recorded wavelengths of light: an infrared picture'
% See properties

% Modelets play roles when used by engines. They can be associated with an extrinsic (to the modelet) purpose.
% TODO: this looks like it will turn out to be HOL
tff(decl_role_of_modelet, type,
  is_role_of_modelet : (modelet * role) > $o
).


% Set of Modelets
tff(decl_modelet_set, type,
  modelet_set : $tType
).

% Set Membership of Modelets
tff(decl_set_m_membership, type,
  is_in_modelet_set : (modelet * modelet_set) > $o
).

% (Finite) modelet sets

tff(empty_modelet_set, type,
  ms_empty : modelet_set
).

tff(modelet_set_empty, axiom,
  ![M: modelet]:
    ~ is_in_modelet_set(M, ms_empty)
).

tff(modelet_set_add, type,
  s : (modelet * modelet_set) > modelet_set
).

tff(modelet_set_insert, axiom,
  ![M1: modelet, M2: modelet, MS: modelet_set]:
  (
    is_in_modelet_set(M1, s(M2, MS))
    <=>
    (is_in_modelet_set(M1, MS) | M1 = M2)
  )
).


% Exertion of a Modelet Set results in a Modelet
tff(decl_exert, type,
  exert: (engine * modelet_set) > modelet
).

% Engines impart formalisms unto Modelets
tff(axiom_engine_may_impart_topic, axiom,
  ![E: engine, MS: modelet_set]:
    formalism_of_modelet(exert(E, MS)) = output_modelet_formalism(E)
).

% Engines may impart roles unto Modelets
tff(axiom_engine_may_impart_role, axiom,
  ![E: engine, MS: modelet_set, R: role, M: modelet]:
  (
    is_output_modelet_role(E, R)
    =>
    is_role_of_modelet(exert(E, MS), R)
  )
).

% Engines may impart topic unto Modelets
tff(axiom_engine_may_impart_topic, axiom,
  ![E: engine, MS: modelet_set, P: phenomenon_class, M: modelet]:
  (
    is_output_modelet_topic(E, P)
    =>
    is_topic_of_modelet(exert(E, MS), P)
  )
).

% Templates. Descriptions of Engine Inputs.
tff(decl_template, type,
  template : $tType
).

% Each Template has exactly one formalism. The language a given Engine expects for this input. A ROSMessage.
tff(decl_formalism_of_template, type,
  formalism_of_template : template > formalism
).

% Templates may be located. Center of spatio-temporal scope.
tff(decl_template_location, type,
  template_location : template > spacetime_point
).

% Templates may extend over lenth/area/volume/time. Extent of spatio-temporal scope.
tff(decl_template_extent, type,
  template_extent : template > extent
).

% Templates may be associated with a concept/have a topic. A class in the world model. 'A template of icecream'
tff(decl_topic_of_template, type,
  is_topic_of_template : (template * phenomenon_class) > $o
).

% Templates may carry model characteristic requirements. e.g. 'minimun resolution'
% See properties

% Templates carry Role requirements. Extrinsic (from the perspective of the modelet) purpose.
tff(decl_role_of_template, type,
  is_role_of_template : (template * role) > $o
).


% Set of Templates
tff(decl_template_set, type,
  template_set : $tType
).

% Set Membership of Templates
tff(decl_set_template_membership, type,
  is_in_template_set : (template * template_set) > $o
).






% Modelets can match Templates
tff(decl_inputs_match, type,
  inputs_match : (modelet * template) > $o
).




% Engines have template sets as interface definition
tff(decl_engine_input, type,
  interface_of: (engine) > template_set
).



% Sets of Modelets can match Sets of Modelet Templates
tff(decl_interfaces_match, type,
  interfaces_match : (modelet_set * template_set) > $o
).

% Modelet Sets can be exerted by Engines
tff(decl_exertable, type,
  exertable: (modelet_set * engine) > $o
).


% Modelet Sets are exertable by Engines
tff(axiom_modelet_set_is_exertable, axiom,
  ! [MS: modelet_set, E : engine]:
  (
   interfaces_match(MS, interface_of(E))
   =>
   exertable(MS, E)
  )
).


