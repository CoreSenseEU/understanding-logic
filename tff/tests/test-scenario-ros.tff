  )
).

%%%  properties and requirements  %%%
tff(property_1_decl, type, prop_1 : property).
tff(property_1_uses_formalism_decl, axiom,
  type_of_p(prop_1) = 'ROS2.msg.Uint8'
).
tff(property_1_has_value_4, axiom,
  has_value(prop_1) = four
).

tff(requirement_1_decl, type, req_1 : requirement).
tff(requirement_1_uses_formalism_decl, axiom,
  type_of_r(req_1) = 'ROS2.msg.Uint8'
).
tff(requirement_1_has_permissible_value_4, axiom,
  is_permissible(req_1, four)
).

